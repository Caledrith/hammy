# Shopify Admin API (Dev Dashboard app, client-credentials grant)
SHOPIFY_CLIENT_ID=your_client_id
SHOPIFY_SECRET=your_client_secret
# Use the .myshopify.com domain, NOT the storefront domain
SHOPIFY_STORE=your-store.myshopify.com
# Pinned Admin API version
SHOPIFY_API_VERSION=2026-07

# Postgres (matches docker-compose.yml defaults)
DATABASE_URL=postgres://hammy:hammy@localhost:5432/hammy

# Shared secret the slicer worker presents on /api/worker/* calls. Set the same
# value in the worker's scripts/worker/.env. Leave blank to disable the worker API.
WORKER_TOKEN=change-me-to-a-long-random-string
