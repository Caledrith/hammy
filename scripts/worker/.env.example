# Slicer worker config (shop PC). Copy to scripts/worker/.env and fill in.

# Public URL of the deployed Hammy server (no trailing slash).
SERVER_URL=https://hammy.example.com
# Must equal the server's WORKER_TOKEN.
WORKER_TOKEN=change-me-to-a-long-random-string

# Root of the STL library on this machine. Paths in the DB are relative to this.
# Windows example: D:\models
MODELS_ROOT=/path/to/models

# Bambu Studio CLI-capable executable.
# Windows example: C:\Program Files\Bambu Studio\bambu-studio.exe
BAMBU_CLI_PATH=/Applications/BambuStudio.app/Contents/MacOS/BambuStudio

# Where exported .gcode.3mf files are written (kept local; operator opens them).
# Windows example: D:\plates-out
OUTPUT_DIR=/path/to/plates-out

# Optional. Defaults to the repo's profiles/ folder.
# PROFILES_ROOT=/path/to/hammy/profiles

# Optional. Poll interval in milliseconds (default 15000).
# POLL_INTERVAL_MS=15000
